# Default backend: mysql
DB_BACKEND=mysql

DB_HOST=localhost
DB_PORT=3306
DB_NAME=ocuwell_gateway
DB_USER=ocuwell_app
DB_PASSWORD=change_me

# Optional override:
# DATABASE_URL=mysql+pymysql://ocuwell_app:change_me@localhost:3306/ocuwell_gateway

# Azure SQL option:
# DB_BACKEND=azure_sql
# AZURE_SQL_AUTH_MODE=entra
# AZURE_SQL_SERVER=ocuwell-gateway-dev.database.windows.net
# AZURE_SQL_PORT=1433
# AZURE_SQL_DATABASE=ocuwell_gateway
# AZURE_SQL_DRIVER=ODBC Driver 18 for SQL Server
# AZURE_SQL_ENCRYPT=yes
# AZURE_SQL_TRUST_SERVER_CERTIFICATE=no
# AZURE_SQL_CONNECTION_TIMEOUT=30
# AZURE_SQL_EXCLUDE_INTERACTIVE_BROWSER_CREDENTIAL=true
#
# Optional SQL login fallback:
# AZURE_SQL_AUTH_MODE=sql_password
# AZURE_SQL_USERNAME=ocuwell_admin
# AZURE_SQL_PASSWORD=change_me

# LicenseSpring credentials stay only on this cloud gateway. Do not ship these
# values in the desktop application or frontend bundle.
LICENSESPRING_API_KEY=
LICENSESPRING_SHARED_KEY=
LICENSESPRING_PRODUCT_CODE=
LICENSESPRING_API_PROTOCOL=https
LICENSESPRING_API_DOMAIN=api.licensespring.com
LICENSESPRING_API_VERSION=v4
